  "lecciones": {
    "lec-aritmetica": {
      "id": "lec-aritmetica",
      "titulo": "¿Qué es una variable?",
      "unidadId": "u1",
      "videoUrl": "/manim/AritmeticaAlgebra.mp4",
      "duracion": "01:30",
      "ideasClave": [
        "El álgebra no es más difícil que la aritmética.",
        "La x no es un monstruo, es una etiqueta."
      ],
      "concepto": "Variables",
      "conceptoDetalle": "Una letra simplemente es el nombre que le ponemos a una caja con un número misterioso."
    },
    "lec-exponentes": {
      "id": "lec-exponentes",
      "titulo": "Leyes de los Exponentes",
      "unidadId": "u2",
      "videoUrl": "/manim/LeyesExponentes.mp4",
      "duracion": "01:00",
      "ideasClave": [
        "Multiplicar la misma base suma exponentes.",
        "Si entiendes de dónde salen, ya no se te olvidan."
      ],
      "concepto": "Leyes de Exponentes",
      "conceptoDetalle": "Las fórmulas son solo un atajo para no escribir las potencias extendidas."
    },
    "lec-balanza": {
      "id": "lec-balanza",
      "titulo": "Ecuación Balanza: 2x + 5 = 8",
      "unidadId": "u3",
      "videoUrl": "/manim/EcuacionBalanza.mp4",
      "duracion": "00:45",
      "ideasClave": [
        "Una ecuación es una balanza en equilibrio.",
        "Para mantenerla estable, lo que haces de un lado, hazlo del otro."
      ],
      "concepto": "Despeje de Ecuaciones",
      "conceptoDetalle": "Resuelve la ecuación sin desbalancear la igualdad en ningún momento."
    },
    "lec-productos": {
      "id": "lec-productos",
      "titulo": "Productos Notables",
      "unidadId": "u4",
      "videoUrl": "/manim/ProductosNotables.mp4",
      "duracion": "01:10",
      "ideasClave": [
        "Un producto notable no es una fórmula mágica, es un área.",
        "Podemos visualizar (a+b)² como un cuadrado formado por 4 piezas."
      ],
      "concepto": "Áreas y Álgebra",
      "conceptoDetalle": "Aprenderás a multiplicar binomios usando representaciones geométricas."
    },
    "lec-diferencia": {
      "id": "lec-diferencia",
      "titulo": "Diferencia de Cuadrados",
      "unidadId": "u4",
      "videoUrl": "/manim/DiferenciaDeCuadrados.mp4",
      "duracion": "01:00",
      "ideasClave": [
        "Al quitar b² de a², nos queda una figura en L.",
        "Podemos reacomodar esa figura en un rectángulo de (a+b)(a-b)."
      ],
      "concepto": "Geometría en la Factorización",
      "conceptoDetalle": "La diferencia de dos cuadrados siempre se factoriza como el producto de dos binomios conjugados."
    },
    "lec-pitagoras": {
      "id": "lec-pitagoras",
      "titulo": "Teorema de Pitágoras",
      "unidadId": "u5",
      "videoUrl": "/manim/TeoremaPitagoras.mp4",
      "duracion": "00:50",
      "ideasClave": [
        "No es una fórmula abstracta. Son tres cuadrados reales.",
        "Las áreas pequeñas caben exactamente en la grande."
      ],
      "concepto": "Triángulos Rectángulos",
      "conceptoDetalle": "El cuadrado de la hipotenusa es igual a la suma de los cuadrados de los catetos."
    }
  },
  "retos": {
    "lec-aritmetica": [
      {
        "id": "reto-aritmetica-1",
        "tipo": "opcion",
        "pregunta": "¿Qué representa la letra 'x' en álgebra?",
        "opciones": [
          {
            "id": "a",
            "texto": "Una caja con un número misterioso",
            "ok": true
          },
          {
            "id": "b",
            "texto": "Un error en la fórmula",
            "ok": false,
            "reflexion": "Recuerda que la x es como una etiqueta para algo que queremos descubrir."
          },
          {
            "id": "c",
            "texto": "Una operación imposible",
            "ok": false,
            "reflexion": "No es imposible, es un valor que debemos despejar."
          }
        ],
        "pista": "Piensa en el ejemplo de la caja fuerte."
      }
    ],
    "lec-exponentes": [
      {
        "id": "reto-exponentes-1",
        "tipo": "opcion",
        "pregunta": "Si tengo a³ * a², ¿Qué hago con los exponentes?",
        "opciones": [
          {
            "id": "a",
            "texto": "Los sumo, el resultado es a⁵",
            "ok": true
          },
          {
            "id": "b",
            "texto": "Los multiplico, el resultado es a⁶",
            "ok": false,
            "reflexion": "Recuerda que a³ son 3 letras 'a' multiplicadas y a² son 2. En total cuántas hay?"
          },
          {
            "id": "c",
            "texto": "No se pueden combinar",
            "ok": false,
            "reflexion": "Tienen la misma base 'a', sí se pueden combinar."
          }
        ],
        "pista": "Escribe la forma extendida: (a*a*a) * (a*a)"
      }
    ],
    "lec-balanza": [
      {
        "id": "reto-balanza-1",
        "tipo": "balanza",
        "pregunta": "Resuelve la ecuación 2x + 5 = 8",
        "opciones": [],
        "pista": "Primero elimina las bolitas de ambos lados al mismo tiempo arrastrándolas a la caneca."
      }
    ],
    "lec-productos": [
      {
        "id": "reto-productos-1",
        "tipo": "opcion",
        "pregunta": "¿Cuál es el área total de un cuadrado de lado (a+b)?",
        "opciones": [
          {
            "id": "a",
            "texto": "a² + 2ab + b²",
            "ok": true
          },
          {
            "id": "b",
            "texto": "a² + b²",
            "ok": false,
            "reflexion": "Si solo sumas los cuadrados pequeños, estás olvidando los dos rectángulos de ab."
          },
          {
            "id": "c",
            "texto": "2a + 2b",
            "ok": false,
            "reflexion": "Ese es el perímetro, no el área."
          }
        ],
        "pista": "Recuerda las 4 piezas del cuadrado: una de a², una de b², y dos rectángulos de ab."
      }
    ],
    "lec-diferencia": [
      {
        "id": "reto-diferencia-1",
        "tipo": "opcion",
        "pregunta": "La diferencia de cuadrados a² - b² se puede factorizar como:",
        "opciones": [
          {
            "id": "a",
            "texto": "(a+b)(a-b)",
            "ok": true
          },
          {
            "id": "b",
            "texto": "(a-b)²",
            "ok": false,
            "reflexion": "Ese es el cuadrado de un binomio, no la diferencia de cuadrados."
          },
          {
            "id": "c",
            "texto": "a² + b²",
            "ok": false,
            "reflexion": "Eso es una suma de cuadrados, la cual no es factorizable en los reales."
          }
        ],
        "pista": "Piensa en las dimensiones del rectángulo final cuando rearmamos la figura en forma de L."
      }
    ],
    "lec-pitagoras": [
      {
        "id": "reto-pitagoras-1",
        "tipo": "opcion",
        "pregunta": "En un triángulo rectángulo, ¿cómo se relacionan las áreas construidas sobre los lados?",
        "opciones": [
          {
            "id": "a",
            "texto": "El área del cuadrado mayor es igual a la suma de las áreas de los dos cuadrados menores.",
            "ok": true
          },
          {
            "id": "b",
            "texto": "La suma de los tres cuadrados siempre es cero.",
            "ok": false,
            "reflexion": "Las áreas son siempre números positivos."
          },
          {
            "id": "c",
            "texto": "El cuadrado de un cateto es la suma de los otros dos cuadrados.",
            "ok": false,
            "reflexion": "La hipotenusa (el lado más largo) es el que lleva la suma de los dos pequeños."
          }
        ],
        "pista": "Recuerda cómo los cuadrados de áreas 9 y 16 llenaron exactamente el de área 25."
      }
    ]
  },
